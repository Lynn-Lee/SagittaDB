# ─── 数据库 ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sagitta:sagitta123@postgres:5432/sagittadb
# 同步 URL，仅供 Alembic migration 使用
DATABASE_URL_SYNC=postgresql+psycopg2://sagitta:sagitta123@postgres:5432/sagittadb

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:redis123@redis:6379/0
REDIS_PASSWORD=redis123

# ─── 安全 ─────────────────────────────────────────────────────
# 生产环境请替换为随机 32+ 字符字符串
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_RANDOM_32_CHARS
# JWT 访问令牌有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60
# JWT 刷新令牌有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 多租户（SaaS 预留，企业版固定为 1）────────────────────────
TENANT_ID=1

# ─── 可观测中心 ────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://localhost:3000
GRAFANA_CLIENT_ID=sagitta
GRAFANA_CLIENT_SECRET=CHANGE_ME

# ─── AI 能力（可选）──────────────────────────────────────────
# openai / anthropic / none
AI_PROVIDER=none
AI_API_KEY=

# ─── goInception（可选增强，不强制依赖）──────────────────────
ENABLE_GOINCEPTION=false
GO_INCEPTION_HOST=goinception:4000

# ─── 认证扩展（可选）─────────────────────────────────────────
LDAP_ENABLED=false
LDAP_SERVER_URI=ldap://ldap:389
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_DN_TEMPLATE=uid=%(user)s,ou=users,dc=example,dc=com

OIDC_ENABLED=false
OIDC_OP_AUTHORIZATION_ENDPOINT=
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_JWKS_ENDPOINT=
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=

# ─── 对象存储（导出文件）────────────────────────────────────
# local / s3 / oss / azure
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/downloads

# S3 / OSS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=

# ─── 通知（可选）─────────────────────────────────────────────
DINGTALK_WEBHOOK=
FEISHU_WEBHOOK=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── PostgreSQL（Docker Compose 用）──────────────────────────
POSTGRES_DB=sagittadb
POSTGRES_USER=sagitta
POSTGRES_PASSWORD=sagitta123

# ─── 应用环境 ─────────────────────────────────────────────────
# development / production
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
